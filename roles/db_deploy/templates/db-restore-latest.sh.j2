#!/usr/bin/env bash
set -euo pipefail
cd /var/lib/postgresql

BACKUP_DIR="{{ db_backup_dir }}"
TARGET_DB="${1:-{{ db_import_name }}}"
TARGET_OWNER="${2:-{{ db_import_user }}}"

LATEST_BACKUP=$(find "$BACKUP_DIR" -maxdepth 1 -type f -name "${TARGET_DB}_*.dump" -printf '%T@ %p
' | sort -nr | head -n 1 | cut -d' ' -f2-)

if [ -z "$LATEST_BACKUP" ]; then
  echo "Backup file for database ${TARGET_DB} not found"
  exit 1
fi

echo "Restoring ${TARGET_DB} from: ${LATEST_BACKUP}"
dropdb --if-exists "$TARGET_DB"
createdb -O "$TARGET_OWNER" "$TARGET_DB"
pg_restore --exit-on-error --no-owner --role="$TARGET_OWNER" -d "$TARGET_DB" "$LATEST_BACKUP"
psql -d "$TARGET_DB" -c "GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO ${TARGET_OWNER};"
psql -d "$TARGET_DB" -c "GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO ${TARGET_OWNER};"
psql -d "$TARGET_DB" -c "GRANT ALL PRIVILEGES ON ALL FUNCTIONS IN SCHEMA public TO ${TARGET_OWNER};"
echo "Restore completed"
