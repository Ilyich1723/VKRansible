#!/usr/bin/env bash
set -euo pipefail
umask 007
cd /var/lib/postgresql

BACKUP_DIR="{{ db_backup_dir }}"
RETENTION_DAYS="{{ db_backup_retention_days }}"
TIMESTAMP="$(date +%F_%H-%M-%S)"

mkdir -p "$BACKUP_DIR"

backup_one_db() {
  local db_name="$1"
  [ -n "$db_name" ] || return 0

  if psql -tAc "SELECT 1 FROM pg_database WHERE datname='${db_name}'" | grep -qx '1'; then
    local backup_file="${BACKUP_DIR}/${db_name}_${TIMESTAMP}.dump"
    pg_dump -Fc -d "$db_name" -f "$backup_file"
    find "$BACKUP_DIR" -type f -name "${db_name}_*.dump" -mtime +${RETENTION_DAYS} -delete
    echo "Backup created: ${backup_file}"
  else
    echo "Database ${db_name} not found, skipping"
  fi
}

{% for db in db_backup_databases %}
backup_one_db "{{ db }}"
{% endfor %}

GLOBALS_FILE="${BACKUP_DIR}/globals_${TIMESTAMP}.sql"
pg_dumpall --globals-only > "$GLOBALS_FILE"
find "$BACKUP_DIR" -type f -name 'globals_*.sql' -mtime +${RETENTION_DAYS} -delete

echo "Globals backup created: ${GLOBALS_FILE}"
